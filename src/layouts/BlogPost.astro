---
import Layout from './Layout.astro';

const { title, date, description } = Astro.props.frontmatter;
---

<Layout title={title}>
  <div class="max-w-2xl mx-auto">
    <div class="mb-8">
      <p class="text-sm text-gray-400 dark:text-gray-500 mb-2">{date}</p>
      <h1 class="text-3xl font-bold tracking-tight">{title}</h1>
      {description && <p class="text-gray-500 dark:text-gray-400 mt-2">{description}</p>}
    </div>
    <article class="prose prose-gray dark:prose-invert max-w-none">
      <slot />
    </article>
    <div class="mt-10 pt-6 border-t border-gray-200 dark:border-gray-800">
      <a href="/blog/" class="text-sm text-blue-600 dark:text-blue-400 hover:underline">&larr; All posts</a>
    </div>
  </div>
</Layout>
