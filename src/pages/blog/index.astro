---
import Layout from '../../layouts/Layout.astro';

const postModules = import.meta.glob('./*.md', { eager: true }) as Record<string, { frontmatter: Record<string, string>; url?: string }>;
const sorted = Object.entries(postModules)
  .map(([path, mod]) => ({
    ...mod.frontmatter,
    url: '/blog/' + path.replace('./', '').replace('.md', '/'),
  }))
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<Layout title="Blog">
  <div class="max-w-2xl mx-auto">
    <div class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight">Blog</h1>
      <p class="text-gray-500 dark:text-gray-400 mt-1">Thoughts and notes</p>
    </div>

    {sorted.length === 0 ? (
      <p class="text-gray-400 dark:text-gray-500">No posts yet.</p>
    ) : (
      <ul class="space-y-6">
        {sorted.map((post) => (
          <li>
            <a href={post.url} class="group block bg-white dark:bg-gray-900 rounded-2xl border border-gray-200 dark:border-gray-800 p-6 shadow-sm hover:border-blue-300 dark:hover:border-blue-700 transition-colors">
              <p class="text-xs text-gray-400 dark:text-gray-500 mb-1">{post.date}</p>
              <h2 class="text-lg font-semibold group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{post.title}</h2>
              {post.description && (
                <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">{post.description}</p>
              )}
            </a>
          </li>
        ))}
      </ul>
    )}
  </div>
</Layout>
