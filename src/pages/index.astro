---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <div class="flex flex-col items-center justify-center min-h-[60vh] text-center">
    <!-- Hero -->
    <div class="space-y-6 max-w-2xl">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm font-medium">
        <span class="w-2 h-2 rounded-full bg-blue-500 animate-pulse"></span>
        Investment Dashboard
      </div>

      <h1 class="text-5xl sm:text-6xl font-bold tracking-tight">
        Hi, I'm <span class="text-blue-600 dark:text-blue-400">Justin</span>
      </h1>

      <p class="text-lg text-gray-600 dark:text-gray-400 leading-relaxed">
        Tracking my investment portfolio — allocation shifts, cost basis vs. market value, and performance over time.
      </p>

      <div class="flex flex-col sm:flex-row gap-3 justify-center pt-4">
        <a
          href="/stocks/"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-medium transition-colors shadow-lg shadow-blue-600/25"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
          </svg>
          View Portfolio
        </a>
        <a
          href="/allocation/"
          class="inline-flex items-center justify-center gap-2 px-6 py-3 bg-gray-100 dark:bg-gray-800 hover:bg-gray-200 dark:hover:bg-gray-700 text-gray-900 dark:text-gray-100 rounded-xl font-medium transition-colors"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6a7.5 7.5 0 107.5 7.5h-7.5V6z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 10.5H21A7.5 7.5 0 0013.5 3v7.5z" />
          </svg>
          Allocation Trends
        </a>
      </div>
    </div>

    <!-- Quick stats cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mt-16 w-full max-w-3xl" id="stats-cards">
      <div class="bg-white dark:bg-gray-900 rounded-2xl p-6 border border-gray-200 dark:border-gray-800 shadow-sm">
        <p class="text-sm text-gray-500 dark:text-gray-400">Snapshots</p>
        <p class="text-3xl font-bold mt-1">5</p>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Dec 2023 — Sep 2025</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-2xl p-6 border border-gray-200 dark:border-gray-800 shadow-sm">
        <p class="text-sm text-gray-500 dark:text-gray-400">Asset Types</p>
        <p class="text-3xl font-bold mt-1">5</p>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Index, Stock, Crypto, Cash, Bond</p>
      </div>
      <div class="bg-white dark:bg-gray-900 rounded-2xl p-6 border border-gray-200 dark:border-gray-800 shadow-sm">
        <p class="text-sm text-gray-500 dark:text-gray-400">Dashboards</p>
        <p class="text-3xl font-bold mt-1">2</p>
        <p class="text-xs text-gray-400 dark:text-gray-500 mt-1">Portfolio detail & allocation trends</p>
      </div>
    </div>
  </div>
</Layout>
